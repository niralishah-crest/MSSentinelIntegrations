                        { "name": "ErrorMessage", "type": "string" },
                        { "name": "Location", "type": "string" },
                        { "name": "Url", "type": "string" },
                        { "name": "CustomerId", "type": "string" },
                        { "name": "LogicalSizeInBytes", "type": "long" },
                        { "name": "DataTransferredInBytes", "type": "long" },
                        { "name": "EffectiveThroughput", "type": "long" },
                        { "name": "SnapshotId", "type": "string" }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('WorkspaceName'), '/', parameters('RansomwareAnalysisTableName'))]",
            "properties": {
                "schema": {
                    "name": "[parameters('RansomwareAnalysisTableName')]",
                    "columns": [
                        { "name": "TimeGenerated", "type": "datetime" },
                        { "name": "Summary", "type": "string" },
                        { "name": "EventSource", "type": "string" },
                        { "name": "Severity", "type": "string" },
                        { "name": "EventTimestamp", "type": "datetime" },
