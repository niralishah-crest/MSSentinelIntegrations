                        { "name": "Status", "type": "string" },
                        { "name": "ClusterName", "type": "string" },
                        { "name": "ClusterId", "type": "string" },
                        { "name": "EventName", "type": "string" },
                        { "name": "ErrorId", "type": "string" },
                        { "name": "ErrorCode", "type": "string" },
                        { "name": "ErrorRemedy", "type": "string" },
